{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Home Assistant",
            "type": "debugpy",
            "request": "launch",
            "module": "homeassistant",
            "args": [
                "--config",
                "${workspaceFolder}/config",
                "--debug"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}/custom_components"
            },
            "justMyCode": false,
        }
    ]
}